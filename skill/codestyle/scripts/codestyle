#!/bin/bash
# Codestyle CLI Wrapper - 简化版
# 静默自动初始化，只在首次使用时提示一次

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JAR_FILE="$SCRIPT_DIR/codestyle-server.jar"
INIT_MARKER="$SCRIPT_DIR/.initialized"

# 检查首次使用
if [ ! -f "$INIT_MARKER" ]; then
    echo ""
    echo "[Codestyle] 首次使用，正在初始化..."
    echo ""
    
    # 自动安装 JAR
    if [ ! -f "$JAR_FILE" ]; then
        echo "[1/2] 下载 JAR 文件..."
        bash "$SCRIPT_DIR/install.sh" >/dev/null 2>&1
        if [ $? -ne 0 ]; then
            echo "❌ JAR 下载失败"
            echo ""
            echo "请检查："
            echo "  1. 网络连接"
            echo "  2. Java 17+ 已安装"
            echo ""
            exit 1
        fi
        echo "✓ JAR 下载完成"
    fi
    
    # 自动初始化仓库
    echo "[2/2] 克隆模板仓库..."
    bash "$SCRIPT_DIR/init-repository.sh" >/dev/null 2>&1
    if [ $? -ne 0 ]; then
        echo "  仓库克隆失败"
        echo ""
        echo "手动修复："
        echo "  1. 下载: https://github.com/itxaiohanglover/codestyle-repository/archive/refs/heads/main.zip"
        echo "  2. 解压到: ~/.codestyle/cache/codestyle-cache"
        echo ""
        read -p "继续使用（模板为空）？ (Y/n): " -n 1 -r
        echo ""
        if [[ $REPLY =~ ^[Nn]$ ]]; then
            exit 1
        fi
    else
        echo "✓ 仓库克隆完成"
    fi
    
    # 创建标记
    touch "$INIT_MARKER"
    echo ""
    echo "✓ 初始化完成"
    echo ""
fi

# 执行命令
java -jar "$JAR_FILE" "$@"
